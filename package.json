{
  "name": "it-aul-landing",
  "version": "1.0.0",
  "description": "Landing page for IT-AUL development team",
  "main": "index.js",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:analyze": "webpack --mode production --env analyze",
    "build:preview": "npm run build && npx serve dist -l 3001",
    "serve": "webpack serve --mode production --open",
    "clean": "rimraf dist .cache",
    "convert-avatars": "node scripts/convert-avatars.js",
    "generate-favicon": "node scripts/generate-favicon.js",
    "optimize-images": "node scripts/optimize-images.js",
    "lint:css": "stylelint 'src/**/*.css' --fix",
    "prebuild": "npm run clean"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "babel-loader": "^9.1.3",
    "compression-webpack-plugin": "^11.0.0",
    "copy-webpack-plugin": "^13.0.0",
    "core-js": "^3.33.0",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "file-loader": "^6.2.0",
    "html-loader": "^4.2.0",
    "html-webpack-plugin": "^5.6.0",
    "image-minimizer-webpack-plugin": "^4.0.0",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.32",
    "postcss-loader": "^7.3.4",
    "postcss-preset-env": "^9.3.0",
    "rimraf": "^5.0.5",
    "sharp": "^0.33.5",
    "style-loader": "^3.3.3",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.89.0",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead",
    "not op_mini all"
  ],
  "sideEffects": [
    "*.css"
  ]
}
