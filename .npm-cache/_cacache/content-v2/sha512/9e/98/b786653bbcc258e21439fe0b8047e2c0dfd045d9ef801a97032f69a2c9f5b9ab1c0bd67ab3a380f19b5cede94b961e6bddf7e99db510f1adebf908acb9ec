ottle(async () => {\n  console.log('Processing', url)\n  const res = await fetch(url)\n  const data = await res.text()\n  const $ = cheerio(data)\n  return $('title').text()\n})))\n.then((titles) => console.log('Titles:', titles))\n```\n\nTo run this example:\n\n```\ngit clone git@github.com:zeit/async-throttle\ncd async-throttle\nnpm install\nnpm run example\n```\n","maintainers":[{"email":"nathan@tootallnate.net","name":"tootallnate"},{"email":"rauchg@gmail.com","name":"rauchg"}],"time":{"modified":"2022-06-13T03:37:55.873Z","created":"2016-09-30T19:29:40.746Z","0.0.1":"2016-09-30T19:29:40.746Z","1.0.0":"2016-10-26T18:14:26.136Z","1.1.0":"2017-02-16T18:14:02.125Z"},"homepage":"https://github.com/zeit/async-throttle#readme","repository":{"type":"git","url":"git+https://github.com/zeit/async-throttle.git"},"bugs":{"url":"https://github.com/zeit/async-throttle/issues"},"license":"MIT","readmeFilename":"README.md","users":{"leedm777":true,"subinvarghesein":true}}